{
  "name": "n8n-nodes-sendseven",
  "version": "1.2.7",
  "description": "n8n community node for SendSeven - Unified Messaging API Platform",
  "keywords": [
    "n8n-community-node-package",
    "sendseven",
    "messaging",
    "whatsapp",
    "telegram",
    "sms",
    "email"
  ],
  "license": "MIT",
  "homepage": "https://sendseven.com",
  "author": {
    "name": "SendSeven GmbH",
    "email": "dev@sendseven.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SendSeven-GmbH/n8n-nodes-sendseven.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node scripts/copy-icons.js",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials",
    "lintfix": "eslint nodes credentials --fix",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/SendSevenApi.credentials.js",
      "dist/credentials/SendSevenOAuth2Api.credentials.js"
    ],
    "nodes": [
      "dist/nodes/SendSeven/SendSeven.node.js",
      "dist/nodes/SendSeven/SendSevenTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.19.43",
    "eslint": "^9.39.4",
    "n8n-workflow": "^1.20.0",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
